CXX_STD = CXX11
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

all: $(SHLIB) ../inst/nimble_lib/nimble_fft.o

../inst/nimble_lib/nimble_fft.o: nimble_fft.o
	rm -f "../inst/nimble_lib/nimble_fft.o"
	cp "nimble_fft.o" "../inst/nimble_lib/nimble_fft.o"
